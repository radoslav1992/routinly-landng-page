---
interface Props {
  heading: string;
  copy: string;
  buttonLabel?: string;
  note?: string;
}

const {
  heading,
  copy,
  buttonLabel = 'Get started free',
  note = 'Free plan · No credit card required',
} = Astro.props;
---

<section class="container cta-section">
  <h2>{heading}</h2>
  <p>{copy}</p>
  <a class="btn btn-primary" href="https://app.routinly.org">{buttonLabel}</a>
  <div class="fine-print">{note}</div>
</section>

<style>
  .cta-section {
    padding-top: 120px;
    padding-bottom: 120px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-section h2 {
    font-weight: 800;
    font-size: clamp(34px, 6vw, 56px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    max-width: 720px;
    text-wrap: balance;
  }

  .cta-section p {
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    margin: 20px 0 0 0;
    max-width: 520px;
  }

  .cta-section .btn {
    margin-top: 32px;
  }

  .cta-section .fine-print {
    margin-top: 14px;
  }

  @media (max-width: 720px) {
    .cta-section {
      padding-top: 80px;
      padding-bottom: 80px;
    }
  }
</style>
