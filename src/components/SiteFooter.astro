---
const columns = [
  {
    heading: 'Product',
    links: [
      { href: '/#features', label: 'Features' },
      { href: '/pricing', label: 'Pricing' },
      { href: '/changelog', label: 'Changelog' },
      { href: 'https://app.routinly.org', label: 'Sign up' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { href: '/blog', label: 'Blog' },
      { href: '/about', label: 'About' },
      { href: '/contact', label: 'Contact' },
      { href: '/contact', label: 'Help center' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy policy' },
      { href: '/terms', label: 'Terms of service' },
      { href: '/cookie-policy', label: 'Cookie policy' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand-row">
          <div class="logo-tile">
            <img src="/images/logo.png" alt="" width="36" height="36" />
          </div>
          <span class="brand-name">Routinly</span>
        </div>
        <p>Turn screen recordings into step-by-step SOPs with AI. Documentation, simplified.</p>
        <div class="social-links">
          <a href="https://twitter.com/routinly">Twitter</a>
          <a href="https://github.com/routinly">GitHub</a>
          <a href="https://linkedin.com/company/routinly">LinkedIn</a>
        </div>
      </div>

      {
        columns.map((column) => (
          <nav class="footer-column" aria-label={`${column.heading} links`}>
            <div class="column-heading">{column.heading}</div>
            {column.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </nav>
        ))
      }
    </div>

    <div class="footer-bottom">
      <span>© {year} Routinly. All rights reserved.</span>
      <span>Built with 🦉 in Europe</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--cream);
  }

  .site-footer .container {
    padding-top: 72px;
    padding-bottom: 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-tile {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .logo-tile img {
    width: 36px;
    height: 36px;
    object-fit: cover;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.02em;
  }

  .footer-brand p {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--cream-62);
    max-width: 300px;
  }

  .social-links {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }

  .social-links a {
    color: var(--cream-62);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }

  .social-links a:hover {
    color: var(--cream);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .column-heading {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cream-45);
    margin-bottom: 6px;
  }

  .footer-column a {
    color: rgba(250, 246, 238, 0.78);
    text-decoration: none;
    font-size: 15px;
  }

  .footer-column a:hover {
    color: var(--cream);
  }

  .footer-bottom {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid rgba(250, 246, 238, 0.14);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .footer-bottom span {
    font-size: 14px;
    color: var(--cream-50);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
