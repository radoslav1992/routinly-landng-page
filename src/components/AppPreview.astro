---
// Schematic illustration of the Routinly app: a recording on the left being
// turned into a numbered SOP on the right. Stands in for the app screenshot
// slot from the design until a real capture is dropped in.
---

<svg
  viewBox="0 0 1040 618"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="app-preview-title"
  class="app-preview"
>
  <title id="app-preview-title">
    The Routinly app turning a screen recording into a step-by-step guide
  </title>

  <!-- Window -->
  <rect width="1040" height="618" rx="8" fill="#FFFDF8" />

  <!-- Title bar -->
  <rect width="1040" height="46" fill="#FAF6EE" />
  <line x1="0" y1="46" x2="1040" y2="46" stroke="#E6DECE" />
  <circle cx="26" cy="23" r="6" fill="#E6DECE" />
  <circle cx="46" cy="23" r="6" fill="#E6DECE" />
  <circle cx="66" cy="23" r="6" fill="#E6DECE" />
  <rect x="420" y="12" width="200" height="22" rx="11" fill="#FFFFFF" stroke="#E6DECE" />
  <text x="520" y="27" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#A8A093">app.routinly.org</text>

  <!-- Left: video panel -->
  <rect x="28" y="74" width="472" height="300" rx="12" fill="#1B1712" />
  <circle cx="264" cy="204" r="38" fill="#C94F1C" />
  <path d="M254 186 L 284 204 L 254 222 Z" fill="#FAF6EE" />
  <!-- timeline -->
  <rect x="52" y="336" width="424" height="6" rx="3" fill="rgba(250,246,238,0.25)" />
  <rect x="52" y="336" width="270" height="6" rx="3" fill="#C94F1C" />
  <circle cx="322" cy="339" r="8" fill="#FAF6EE" />
  <!-- recording chip -->
  <rect x="52" y="94" width="94" height="28" rx="14" fill="rgba(250,246,238,0.14)" />
  <circle cx="70" cy="108" r="5" fill="#C94F1C" />
  <text x="82" y="112" font-family="sans-serif" font-size="12" font-weight="600" fill="#FAF6EE">REC 4:37</text>

  <!-- Left: processing card -->
  <rect x="28" y="398" width="472" height="192" rx="12" fill="#FFFFFF" stroke="#E6DECE" />
  <circle cx="60" cy="436" r="10" fill="#C94F1C" />
  <path d="M55.5 436 l 3 3 l 6 -6" stroke="#FAF6EE" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
  <text x="80" y="441" font-family="sans-serif" font-size="14" font-weight="600" fill="#1B1712">Actions detected</text>
  <circle cx="60" cy="472" r="10" fill="#C94F1C" />
  <path d="M55.5 472 l 3 3 l 6 -6" stroke="#FAF6EE" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
  <text x="80" y="477" font-family="sans-serif" font-size="14" font-weight="600" fill="#1B1712">Screenshots captured</text>
  <circle cx="60" cy="508" r="10" fill="none" stroke="#C94F1C" stroke-width="2.5" stroke-dasharray="4 4" />
  <text x="80" y="513" font-family="sans-serif" font-size="14" font-weight="600" fill="#1B1712">Writing instructions…</text>
  <rect x="50" y="536" width="428" height="8" rx="4" fill="#F0EADC" />
  <rect x="50" y="536" width="300" height="8" rx="4" fill="#E8A87C" />

  <!-- Right: generated SOP -->
  <rect x="528" y="74" width="484" height="516" rx="12" fill="#FFFFFF" stroke="#E6DECE" />
  <rect x="556" y="102" width="252" height="18" rx="9" fill="#1B1712" />
  <rect x="556" y="132" width="180" height="10" rx="5" fill="#E6DECE" />

  <!-- step 1 -->
  <circle cx="572" cy="188" r="14" fill="#C94F1C" />
  <text x="572" y="193" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="700" fill="#FAF6EE">1</text>
  <rect x="600" y="176" width="300" height="10" rx="5" fill="#2E2921" opacity="0.85" />
  <rect x="600" y="194" width="236" height="10" rx="5" fill="#E6DECE" />
  <rect x="600" y="216" width="384" height="64" rx="8" fill="#FAF6EE" stroke="#E6DECE" />
  <rect x="614" y="230" width="120" height="8" rx="4" fill="#E8A87C" />
  <rect x="614" y="246" width="200" height="8" rx="4" fill="#E6DECE" />

  <!-- step 2 -->
  <circle cx="572" cy="322" r="14" fill="#C94F1C" />
  <text x="572" y="327" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="700" fill="#FAF6EE">2</text>
  <rect x="600" y="310" width="330" height="10" rx="5" fill="#2E2921" opacity="0.85" />
  <rect x="600" y="328" width="204" height="10" rx="5" fill="#E6DECE" />
  <rect x="600" y="350" width="384" height="64" rx="8" fill="#FAF6EE" stroke="#E6DECE" />
  <rect x="614" y="364" width="160" height="8" rx="4" fill="#E8A87C" />
  <rect x="614" y="380" width="240" height="8" rx="4" fill="#E6DECE" />

  <!-- step 3 -->
  <circle cx="572" cy="456" r="14" fill="#C94F1C" />
  <text x="572" y="461" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="700" fill="#FAF6EE">3</text>
  <rect x="600" y="444" width="280" height="10" rx="5" fill="#2E2921" opacity="0.85" />
  <rect x="600" y="462" width="256" height="10" rx="5" fill="#E6DECE" />
  <rect x="600" y="484" width="384" height="64" rx="8" fill="#FAF6EE" stroke="#E6DECE" />
  <rect x="614" y="498" width="140" height="8" rx="4" fill="#E8A87C" />
  <rect x="614" y="514" width="220" height="8" rx="4" fill="#E6DECE" />

  <!-- export pill -->
  <rect x="864" y="96" width="120" height="32" rx="16" fill="#C94F1C" />
  <text x="924" y="116" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="600" fill="#FAF6EE">Export</text>
</svg>

<style>
  .app-preview {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 8px;
  }
</style>
