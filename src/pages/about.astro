---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';

const values = [
  {
    title: 'Simplicity first',
    copy: "Complex tools don't get used. We obsess over making every interaction intuitive and every workflow as short as possible.",
  },
  {
    title: 'Quality over quantity',
    copy: "We'd rather ship one feature that works perfectly than ten that are mediocre. Every SOP generated should be genuinely useful.",
  },
  {
    title: 'Team-centric',
    copy: 'Documentation only matters if teams actually use it. We build for collaboration, sharing, and accessibility from day one.',
  },
  {
    title: 'Privacy by design',
    copy: 'Your data is yours. Encryption, role-based access, and strict data policies keep your content safe and private.',
  },
];

const jsonLd = [
  {
    '@type': 'AboutPage',
    name: 'About Routinly',
    url: 'https://routinly.org/about',
    about: { '@id': 'https://routinly.org/#organization' },
  },
];
---

<BaseLayout
  title="About — Routinly"
  description="Routinly turns working knowledge into shareable, AI-generated documentation — so teams can scale without losing what makes them great. Meet the mission and values."
  jsonLd={jsonLd}
>
  <section class="container page-header">
    <div class="eyebrow">About us</div>
    <h1>Great processes shouldn't live in people's heads</h1>
    <p>
      Routinly turns working knowledge into shareable, AI-generated documentation — so teams can
      scale without losing what makes them great.
    </p>
  </section>

  <!-- Mission -->
  <section class="container mission-wrap">
    <div class="mission">
      <div class="mission-copy">
        <div class="mission-eyebrow">Our mission</div>
        <h2>Kill the blank page</h2>
        <p>
          Writing documentation is tedious, so most teams skip it — and critical knowledge lives in
          the minds of a few people. When they leave, it leaves with them.
        </p>
        <p>
          Routinly exists to fix that. Documentation should be a byproduct of your work, not a
          separate chore. Record what you do and let AI handle the rest — no blank page, no
          writer's block, no excuses.
        </p>
      </div>
      <div class="mission-stat">
        <div class="stat-value">&lt; 5 min</div>
        <div class="stat-title">Minutes, not hours</div>
        <p>
          Generate a complete SOP in under five minutes instead of spending an afternoon writing
          one by hand.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="container values">
    <div class="eyebrow">Our values</div>
    <h2 class="section-title">What we stand for</h2>
    <div class="values-grid">
      {
        values.map((value) => (
          <div class="value-card">
            <h3>{value.title}</h3>
            <p>{value.copy}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaSection
    heading="Ready to simplify documentation?"
    copy="Join hundreds of teams creating better SOPs with Routinly."
    buttonLabel="Get started for free"
    note="Free plan available · No credit card required"
  />
</BaseLayout>

<style>
  .page-header {
    padding-top: 88px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-header h1 {
    font-weight: 800;
    font-size: clamp(38px, 6.5vw, 60px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: 16px;
    max-width: 800px;
    text-wrap: balance;
  }

  .page-header p {
    font-size: 19px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 640px;
    margin: 22px 0 0 0;
  }

  .mission-wrap {
    margin-top: 88px;
  }

  .mission {
    background: var(--ink);
    color: var(--cream);
    border-radius: 24px;
    padding: 72px 64px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .mission-copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .mission-eyebrow {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--peach);
  }

  .mission h2 {
    font-weight: 800;
    font-size: clamp(32px, 5vw, 44px);
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .mission-copy p {
    margin: 0;
    font-size: 17px;
    line-height: 1.75;
    color: rgba(250, 246, 238, 0.72);
  }

  .mission-stat {
    background: rgba(250, 246, 238, 0.06);
    border: 1px solid rgba(250, 246, 238, 0.14);
    border-radius: 18px;
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 800;
    color: var(--peach);
    line-height: 1;
  }

  .stat-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
  }

  .mission-stat p {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.65;
    color: rgba(250, 246, 238, 0.65);
  }

  .values {
    padding-top: 110px;
  }

  .section-title {
    font-weight: 800;
    font-size: clamp(32px, 5vw, 44px);
    letter-spacing: -0.02em;
    margin-top: 14px;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 52px;
  }

  .value-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 34px 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .value-card h3 {
    font-size: 22px;
    font-weight: 700;
  }

  .value-card p {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .mission {
      grid-template-columns: 1fr;
      padding: 48px 32px;
      gap: 40px;
    }
  }

  @media (max-width: 720px) {
    .page-header {
      padding-top: 56px;
    }

    .mission-wrap {
      margin-top: 56px;
    }

    .values {
      padding-top: 80px;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
