---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.find((post) => post.data.featured) ?? posts[0];
const rest = posts.filter((post) => post.id !== featured.id);

const longDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const shortDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const jsonLd = [
  {
    '@type': 'Blog',
    name: 'Routinly Blog',
    url: 'https://routinly.org/blog',
    description: 'Guides, opinions, and product updates from the Routinly team.',
    publisher: { '@id': 'https://routinly.org/#organization' },
  },
];
---

<BaseLayout
  title="Blog — Routinly"
  description="Notes on documentation, done better. Guides, opinions, and product updates from the Routinly team."
  jsonLd={jsonLd}
>
  <section class="container blog-header">
    <div class="eyebrow">Blog</div>
    <h1>Notes on documentation, done better</h1>
    <p>Guides, opinions, and product updates from the Routinly team.</p>
  </section>

  <!-- Featured post -->
  <section class="container featured-wrap">
    <a href={`/blog/${featured.id}`} class="featured-card">
      <div class="featured-media">
        <img
          src={featured.data.cover}
          alt=""
          width="640"
          height="480"
          loading="eager"
        />
      </div>
      <div class="featured-body">
        <div class="post-meta">
          <span class="tag-filled">{featured.data.tag}</span>
          <span class="meta-text">
            {longDate(featured.data.pubDate)} · {featured.data.readingTime}
          </span>
        </div>
        <h2>{featured.data.title}</h2>
        <p>{featured.data.description}</p>
        <span class="read-more">Read the guide →</span>
      </div>
    </a>
  </section>

  <!-- Post grid -->
  <section class="container post-grid-wrap">
    <div class="post-grid">
      {
        rest.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-media">
              <img src={post.data.cover} alt="" width="380" height="180" loading="lazy" />
            </div>
            <div class="post-body">
              <div class="post-meta">
                <span class="tag-outline">{post.data.tag}</span>
                <span class="meta-text">{shortDate(post.data.pubDate)}</span>
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding-top: 80px;
  }

  .blog-header h1 {
    font-weight: 800;
    font-size: clamp(36px, 6vw, 56px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: 16px;
    max-width: 700px;
  }

  .blog-header p {
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 560px;
    margin: 18px 0 0 0;
  }

  .featured-wrap {
    padding-top: 56px;
  }

  .featured-card {
    text-decoration: none;
    color: var(--ink);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .featured-card:hover {
    box-shadow: 0 20px 44px -20px rgba(27, 23, 18, 0.25);
    color: var(--ink);
  }

  .featured-media {
    min-height: 340px;
  }

  .featured-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-body {
    padding: 44px 40px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13.5px;
    font-weight: 600;
  }

  .tag-filled {
    background: var(--accent);
    color: var(--cream);
    border-radius: 999px;
    padding: 4px 12px;
  }

  .tag-outline {
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 13px;
  }

  .meta-text {
    color: var(--muted);
    font-weight: 400;
  }

  .featured-body h2 {
    font-size: clamp(24px, 3.5vw, 32px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
  }

  .featured-body p {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--muted);
  }

  .read-more {
    font-size: 15.5px;
    font-weight: 600;
    color: var(--accent);
  }

  .post-grid-wrap {
    padding-top: 48px;
    padding-bottom: 110px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .post-card {
    text-decoration: none;
    color: var(--ink);
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 16px 36px -18px rgba(27, 23, 18, 0.25);
    color: var(--ink);
  }

  .post-media {
    height: 180px;
  }

  .post-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-body {
    padding: 24px 26px 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .post-body h2 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .post-body p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .post-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .blog-header {
      padding-top: 56px;
    }

    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-media {
      min-height: 220px;
      max-height: 280px;
    }

    .featured-body {
      padding: 28px 24px;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
