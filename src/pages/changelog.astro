---
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = [
  {
    date: 'June 30, 2026',
    tag: 'New',
    title: 'Team analytics',
    body: 'Team plan workspaces now include an analytics view: see which SOPs are viewed most, which are going stale, and who on the team is creating documentation.',
  },
  {
    date: 'June 12, 2026',
    tag: 'Improved',
    title: 'Faster processing for long videos',
    body: 'Videos over 20 minutes now process up to 2× faster, and progress is shown step by step so you know exactly where the AI is in your recording.',
  },
  {
    date: 'May 27, 2026',
    tag: 'New',
    title: 'Custom branding for Team exports',
    body: 'Add your logo and brand colors to every exported SOP. Set it once in workspace settings and every PDF, HTML, and shared link picks it up automatically.',
  },
  {
    date: 'May 8, 2026',
    tag: 'Improved',
    title: 'Smarter screenshot selection',
    body: 'The AI now prefers frames where menus and dialogs are fully open, cutting the number of screenshots you need to swap manually by roughly half.',
  },
  {
    date: 'April 30, 2026',
    tag: 'New',
    title: 'Custom writing tone',
    body: 'Tell Routinly how your team writes — formal, friendly, or brief — and every generated SOP matches your voice. Available on Solo and Team plans.',
  },
  {
    date: 'April 9, 2026',
    tag: 'New',
    title: 'YouTube URL import',
    body: 'Paste any YouTube link and Routinly turns the video into a written step-by-step guide. No downloading required. Available on all plans, including Free.',
  },
  {
    date: 'March 24, 2026',
    tag: 'Improved',
    title: 'Markdown export polish',
    body: 'Exported Markdown now uses proper heading hierarchy, embeds screenshots with alt text, and drops cleanly into Notion, Obsidian, and GitHub wikis.',
  },
];
---

<BaseLayout
  title="Changelog — Routinly"
  description="What's new in Routinly: every improvement to the AI SOP generator, in the open. New features and improvements shipped roughly every two weeks."
>
  <section class="container changelog-header">
    <div class="eyebrow">Changelog</div>
    <h1>What's new in Routinly</h1>
    <p>Every improvement, in the open. Shipped roughly every two weeks.</p>
  </section>

  <section class="container entries">
    {
      entries.map((entry) => (
        <article class="entry">
          <div class="entry-meta">
            <time class="entry-date">{entry.date}</time>
            <span class:list={['entry-tag', entry.tag === 'New' ? 'tag-new' : 'tag-improved']}>
              {entry.tag}
            </span>
          </div>
          <div class="entry-body">
            <h2>{entry.title}</h2>
            <p>{entry.body}</p>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .changelog-header,
  .entries {
    max-width: 820px;
  }

  .changelog-header {
    padding-top: 80px;
  }

  .changelog-header h1 {
    font-weight: 800;
    font-size: clamp(36px, 6vw, 54px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: 16px;
  }

  .changelog-header p {
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    margin: 18px 0 0 0;
  }

  .entries {
    padding-top: 64px;
    padding-bottom: 110px;
    display: flex;
    flex-direction: column;
  }

  .entry {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    padding: 36px 0;
    border-top: 1px solid var(--border);
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  .entry-date {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--muted);
  }

  .entry-tag {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 3px 10px;
  }

  .tag-new {
    color: var(--accent);
    border: 1px solid #ebc4ae;
  }

  .tag-improved {
    color: var(--muted);
    border: 1px solid var(--border);
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .entry-body h2 {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .entry-body p {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .changelog-header {
      padding-top: 56px;
    }

    .entry {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 28px 0;
    }

    .entry-meta {
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
  }
</style>
