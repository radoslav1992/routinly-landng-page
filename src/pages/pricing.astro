---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';

const plans = [
  {
    name: 'Free',
    price: '$0',
    tagline: 'Prove it works — on us',
    cta: 'Get started free',
    dark: false,
    features: [
      { label: '3 videos per month', included: true },
      { label: 'AI-generated step instructions', included: true },
      { label: 'Auto-captured screenshots', included: true },
      { label: 'In-app screen recording', included: true },
      { label: 'YouTube URL import', included: true },
      { label: 'Public sharing links', included: true },
      { label: 'Watermarked exports', included: false },
      { label: 'No custom tone or team features', included: false },
    ],
  },
  {
    name: 'Solo',
    price: '$19',
    tagline: 'Everything a professional needs',
    cta: 'Start free trial',
    dark: true,
    features: [
      { label: '20 videos per month', included: true },
      { label: 'Everything in Free', included: true },
      { label: 'Watermark-free exports', included: true, strong: true },
      { label: 'Custom writing tone', included: true, strong: true },
      { label: 'PDF, Markdown & HTML export', included: true },
      { label: 'Priority support', included: true },
      { label: 'No team workspace', included: false },
    ],
  },
  {
    name: 'Team',
    price: '$59',
    tagline: 'One price, unlimited seats',
    cta: 'Start free trial',
    dark: false,
    features: [
      { label: '100 pooled videos per month', included: true },
      { label: 'Everything in Solo', included: true },
      { label: 'Unlimited team seats', included: true, strong: true },
      { label: 'Shared workspace', included: true, strong: true },
      { label: 'Custom branding', included: true, strong: true },
      { label: 'Team analytics & permissions', included: true },
      { label: 'Dedicated account manager', included: true },
      { label: 'SSO & SAML', included: true, soon: true },
    ],
  },
];

const comparisonRows = [
  { feature: 'Monthly videos', free: '3', solo: '20', team: '100 (pooled)' },
  { feature: 'AI step detection', free: '✓', solo: '✓', team: '✓' },
  { feature: 'Auto screenshots', free: '✓', solo: '✓', team: '✓' },
  { feature: 'Screen recording', free: '✓', solo: '✓', team: '✓' },
  { feature: 'YouTube URL import', free: '✓', solo: '✓', team: '✓' },
  { feature: 'Watermark-free exports', free: '—', solo: '✓', team: '✓' },
  { feature: 'PDF / MD / HTML export', free: '—', solo: '✓', team: '✓' },
  { feature: 'Custom writing tone', free: '—', solo: '✓', team: '✓' },
  { feature: 'Team workspace', free: '—', solo: '—', team: '✓' },
  { feature: 'Unlimited seats', free: '—', solo: '—', team: '✓' },
  { feature: 'Custom branding', free: '—', solo: '—', team: '✓' },
  { feature: 'Priority support', free: '—', solo: '✓', team: '✓' },
];

const faqs = [
  {
    question: 'Can I try Routinly for free?',
    answer:
      'Yes. The Free plan gives you 3 SOPs per month with full AI processing — no credit card required.',
  },
  {
    question: 'What happens when I hit my video limit?',
    answer:
      'Your existing SOPs stay accessible. New ones wait until your limit resets next billing cycle — or upgrade any time for more capacity.',
  },
  {
    question: 'Can I switch plans at any time?',
    answer:
      'Absolutely. Upgrade or downgrade whenever you like — upgrades are prorated for the remainder of your billing cycle.',
  },
  {
    question: "How do the Team plan's pooled videos work?",
    answer:
      'Your 100 monthly videos are shared across all members. Anyone can draw from the pool — no per-seat limits to manage.',
  },
  {
    question: 'Do you offer annual billing?',
    answer:
      "It's on the way. Until then, use code LAUNCH90 at checkout for 90% off your first month on any paid plan.",
  },
  {
    question: 'What video formats do you support?',
    answer:
      'MP4, WebM, MP3, WAV, and M4A up to 500MB — or paste a YouTube URL directly, no download needed.',
  },
  {
    question: 'Is my data secure?',
    answer:
      'Yes. Industry-standard encryption and row-level security protect all data. Videos are processed securely, deletable at any time, and never shared with third parties.',
  },
];

const jsonLd = [
  {
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout
  title="Pricing — Routinly"
  description="Start free with 3 AI-generated SOPs a month — no credit card. Solo at $19/month and Team at $59/month with unlimited seats. Compare all Routinly plans."
  jsonLd={jsonLd}
>
  <!-- Header -->
  <section class="container page-header">
    <div class="eyebrow">Pricing</div>
    <h1>One plan for you. One for your whole team.</h1>
    <p>Start free — no credit card. Upgrade when your documentation output demands it.</p>
  </section>

  <!-- Plans -->
  <section class="container plans">
    <div class="plans-grid">
      {
        plans.map((plan) => (
          <div class:list={['plan-card', { dark: plan.dark }]}>
            {plan.dark && <div class="plan-badge">Most popular</div>}
            <div class="plan-head">
              <h2>{plan.name}</h2>
              <div class="plan-price">
                <span class="amount">{plan.price}</span>
                <span class="period">/month</span>
              </div>
              <div class="tagline">{plan.tagline}</div>
            </div>
            <a class:list={['plan-cta', plan.dark ? 'filled' : 'outline']} href="https://app.routinly.org">
              {plan.cta}
            </a>
            <ul class="plan-features">
              {plan.features.map((feature) => (
                <li class:list={[{ excluded: !feature.included }]}>
                  <span class="mark" aria-hidden="true">
                    {feature.included ? '✓' : '✕'}
                  </span>
                  <span>
                    {feature.strong ? <strong>{feature.label}</strong> : feature.label}
                    {feature.soon && <span class="soon-chip">Coming soon</span>}
                  </span>
                </li>
              ))}
            </ul>
            {plan.dark && (
              <div class="promo">
                Use code <strong>LAUNCH90</strong> for 90% off your first month
              </div>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <!-- Comparison table -->
  <section class="container comparison">
    <h2 class="section-title">Compare plans</h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th scope="col">Feature</th>
            <th scope="col">Free</th>
            <th scope="col">Solo</th>
            <th scope="col">Team</th>
          </tr>
        </thead>
        <tbody>
          {
            comparisonRows.map((row) => (
              <tr>
                <th scope="row">{row.feature}</th>
                <td class="free-col">{row.free}</td>
                <td>{row.solo}</td>
                <td>{row.team}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container faq">
    <h2 class="section-title">Frequently asked questions</h2>
    <div class="faq-list">
      {
        faqs.map((faq) => (
          <div class="faq-card">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaSection
    heading="Start creating SOPs today"
    copy="Join hundreds of teams automating their documentation with Routinly."
    buttonLabel="Get started for free"
    note="No credit card required"
  />
</BaseLayout>

<style>
  .page-header {
    padding-top: 80px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-header h1 {
    font-weight: 800;
    font-size: clamp(38px, 6.5vw, 60px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: 16px;
    max-width: 720px;
    text-wrap: balance;
  }

  .page-header p {
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 540px;
    margin: 20px 0 0 0;
  }

  /* Plans */
  .plans {
    padding-top: 64px;
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .plan-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
  }

  .plan-card.dark {
    background: var(--ink);
    color: var(--cream);
    border: none;
    box-shadow: 0 24px 50px -20px rgba(27, 23, 18, 0.4);
  }

  .plan-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--cream);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .plan-head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .plan-head h2 {
    font-size: 22px;
    font-weight: 700;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .plan-price .amount {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 800;
  }

  .plan-price .period,
  .tagline {
    font-size: 15px;
    color: var(--muted);
  }

  .plan-card.dark .plan-price .period,
  .plan-card.dark .tagline {
    color: var(--cream-60);
  }

  .plan-cta {
    display: block;
    text-align: center;
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    border-radius: 999px;
    transition: background 0.15s, color 0.15s;
  }

  .plan-cta.outline {
    border: 1.5px solid var(--ink);
    color: var(--ink);
    padding: 12px 0;
  }

  .plan-cta.outline:hover {
    background: var(--ink);
    color: var(--cream);
  }

  .plan-cta.filled {
    background: var(--accent);
    color: var(--cream);
    padding: 13px 0;
  }

  .plan-cta.filled:hover {
    background: var(--accent-bright);
    color: var(--cream);
  }

  .plan-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
    font-size: 15px;
    line-height: 1.5;
  }

  .plan-features li {
    display: flex;
    gap: 10px;
  }

  .plan-features .mark {
    color: var(--accent);
    font-weight: 700;
  }

  .plan-card.dark .plan-features .mark {
    color: var(--peach);
  }

  .plan-features li.excluded {
    color: var(--faint);
  }

  .plan-features li.excluded .mark {
    color: inherit;
  }

  .plan-card.dark .plan-features li.excluded {
    color: var(--cream-45);
  }

  .soon-chip {
    font-size: 12.5px;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 1px 8px;
    margin-left: 6px;
    white-space: nowrap;
  }

  .promo {
    background: rgba(232, 168, 124, 0.12);
    border: 1px solid rgba(232, 168, 124, 0.3);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13.5px;
    color: var(--peach);
  }

  /* Comparison table */
  .comparison {
    padding-top: 110px;
  }

  .section-title {
    font-weight: 800;
    font-size: clamp(30px, 5vw, 40px);
    letter-spacing: -0.02em;
    margin-bottom: 40px;
  }

  .table-scroll {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
  }

  th,
  td {
    padding: 15px 28px;
    border-bottom: 1px solid var(--row-border);
    font-size: 15px;
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: none;
  }

  thead th {
    background: var(--bg);
    font-weight: 700;
    text-align: center;
  }

  thead th:first-child {
    text-align: left;
  }

  tbody th {
    font-weight: 400;
    text-align: left;
    color: var(--ink);
  }

  td {
    text-align: center;
    color: var(--ink);
  }

  td.free-col {
    color: var(--muted);
  }

  /* FAQ */
  .faq {
    padding-top: 110px;
    max-width: 860px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-card h3 {
    font-size: 18px;
    font-weight: 700;
  }

  .faq-card p {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .plan-card.dark {
      order: -1;
    }
  }

  @media (max-width: 720px) {
    .page-header {
      padding-top: 56px;
    }

    .comparison,
    .faq {
      padding-top: 80px;
    }

    th,
    td {
      padding: 13px 18px;
    }
  }
</style>
