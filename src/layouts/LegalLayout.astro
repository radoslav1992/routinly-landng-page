---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  lastUpdated: string;
}

const { title, description, heading, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="container legal">
    <div class="eyebrow">Legal</div>
    <h1>{heading}</h1>
    <div class="updated">Last updated: {lastUpdated}</div>
    <div class="legal-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: 760px;
    padding-top: 72px;
    padding-bottom: 100px;
  }

  .legal h1 {
    font-weight: 800;
    font-size: clamp(34px, 6vw, 48px);
    letter-spacing: -0.03em;
    margin-top: 14px;
  }

  .updated {
    font-size: 15px;
    color: var(--muted);
    margin-top: 14px;
  }

  .legal-body {
    margin-top: 44px;
    font-size: 16.5px;
    line-height: 1.75;
    color: var(--ink-soft);
  }

  .legal-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.01em;
    margin: 28px 0 12px 0;
    color: var(--ink);
  }

  .legal-body :global(p) {
    margin: 0 0 20px 0;
  }

  .legal-body :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .legal {
      padding-top: 48px;
      padding-bottom: 72px;
    }
  }
</style>
